{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/robots.txt", "/sitemap.xml", "/ads.txt", "/favicon*"]
  },
  "mimeTypes": {
    ".txt": "text/plain",
    ".xml": "application/xml"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
